  invalidateFastCaches_([SHEETS.expenses]);
  return { ok: true, id: expenseId, paidFromCollectedCash };
}

function getAdminHandoverDashboard(form) {
  const admin = clean_(form && form.admin) || clean_(form && form.adminUser);
