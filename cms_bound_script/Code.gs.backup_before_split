    "</style></head><body>" +
    "<h1>St. Michael Church Wuppertal &mdash; Financial Integrity Report</h1>" +
    "<p class='meta'>Generated " + genDate + " by " + clean_(admin) + "</p>" +
    "<div class='status' style='background:" + statusColor + "'>" + report.status + "</div>" +
    summaryBlock +
