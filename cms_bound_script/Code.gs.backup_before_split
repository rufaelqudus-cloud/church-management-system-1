  const phoneQ = q.replace(/\s+/g, "");
  if (index.byPhone[phoneQ]) return index.byPhone[phoneQ];
  return index.list.find(m =>
    m.phone.toLowerCase().replace(/\s+/g, "").includes(phoneQ) ||
    m.name.toLowerCase() === q ||
    m.name.toLowerCase().includes(q)
